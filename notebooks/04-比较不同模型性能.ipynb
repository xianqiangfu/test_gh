{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 比较不同模型性能\n",
    "\n",
    "本笔记本演示如何系统化地比较不同机器学习模型的性能。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import time\n",
    "from sklearn.model_selection import train_test_split, cross_val_score, StratifiedKFold\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.neighbors import KNeighborsClassifier\n",
    "from sklearn.svm import SVC\n",
    "from sklearn.tree import DecisionTreeClassifier\n",
    "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n",
    "from sklearn.naive_bayes import GaussianNB\n",
    "from sklearn.metrics import (\n",
    "    accuracy_score, precision_score, recall_score, f1_score,\n",
    "    confusion_matrix, classification_report, roc_curve, auc\n",
    ")\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# 设置中文字体\n",
    "plt.rcParams['font.sans-serif'] = ['SimHei', 'Arial Unicode MS']\n",
    "plt.rcParams['axes.unicode_minus'] = False\n",
    "sns.set_style('whitegrid')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 加载数据"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 读取鸢尾花数据集\n",
    "df = pd.read_csv('../data/iris.csv')\n",
    "\n",
    "# 只使用两个类别进行二分类（便于 ROC 曲线）\n",
    "df_binary = df[df['species'].isin(['setosa', 'versicolor'])].copy()\n",
    "df_binary['species'] = df_binary['species'].map({'setosa': 0, 'versicolor': 1})\n",
    "\n",
    "X = df_binary.drop('species', axis=1).values\n",
    "y = df_binary['species'].values\n",
    "\n",
    "print(f\"数据形状: {X.shape}\")\n",
    "print(f"类别分布: {np.bincount(y)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 数据准备"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 划分数据集\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.3, random_state=42, stratify=y\n",
    ")\n",
    "\n",
    "# 标准化\n",
    "scaler = StandardScaler()\n",
    "X_train_scaled = scaler.fit_transform(X_train)\n",
    "X_test_scaled = scaler.transform(X_test)\n",
    "\n",
    "print(f"训练集: {X_train_scaled.shape}\")\n",
    "print(f"测试集: {X_test_scaled.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. 定义模型"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 定义要比较的模型\n",
    "models = {\n",
    "    '逻辑回归': LogisticRegression(random_state=42, max_iter=1000),\n",
    "    'K近邻 (k=5)': KNeighborsClassifier(n_neighbors=5),\n",
    "    '线性SVM': SVC(kernel='linear', random_state=42, probability=True),\n",
    "    'RBF SVM': SVC(kernel='rbf', random_state=42, probability=True),\n",
    "    '决策树': DecisionTreeClassifier(random_state=42),\n",
    "    '随机森林': RandomForestClassifier(random_state=42),\n",
    "    '梯度提升': GradientBoostingClassifier(random_state=42),\n",
    "    '朴素贝叶斯': GaussianNB()\n",
    "}\n",
    "\n",
    "print(f\"共 {len(models)} 个模型待比较\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. 训练模型并评估"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 存储结果\n",
    "results = []\n",
    "predictions = {}\n",
    "training_times = {}\n",
    "\n",
    "# 训练每个模型\n",
    "for name, model in models.items():\n",
    "    # 计时训练时间\n",
    "    start_time = time.time()\n",
    "    model.fit(X_train_scaled, y_train)\n",
    "    training_time = time.time() - start_time\n",
    "    training_times[name] = training_time\n",
    "    \n",
    "    # 预测\n",
    "    y_pred = model.predict(X_test_scaled)\n",
    "    y_pred_proba = model.predict_proba(X_test_scaled)[:, 1] if hasattr(model, 'predict_proba') else None\n",
    "    predictions[name] = (y_pred, y_pred_proba)\n",
    "    \n",
    "    # 计算指标\n",
    "    result = {\n",
    "        '模型': name,\n",
    "        '准确率': accuracy_score(y_test, y_pred),\n",
    "        '精确率': precision_score(y_test, y_pred),\n",
    "        '召回率': recall_score(y_test, y_pred),\n",
    "        'F1分数': f1_score(y_test, y_pred),\n",
    "        '训练时间(s)': training_time\n",
    "    }\n",
    "    \n",
    "    # 计算交叉验证分数\n",
    "    cv_scores = cross_val_score(model, X_train_scaled, y_train, cv=5)\n",
    "    result['CV均值'] = cv_scores.mean()\n",
    "    result['CV标准差'] = cv_scores.std()\n",
    "    \n",
    "    results.append(result)\n",
    "    print(f\"{name} 完成 - 准确率: {result['准确率']:.4f}\")\n",
    "\n",
    "# 创建结果 DataFrame\n",
    "results_df = pd.DataFrame(results)\n",
    "results_df = results_df.round(4)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. 结果对比表"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 显示结果表\n",
    "print(\"模型性能对比:\")\n",
    "print(results_df.to_string(index=False))\n",
    "\n",
    "# 找出最佳模型\n",
    "best_model = results_df.loc[results_df['准确率'].idxmax()]\n",
    "print(f\"\\n最佳模型: {best_model['模型']} (准确率: {best_model['准确率']})\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. 可视化对比"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 性能指标对比\n",
    "metrics = ['准确率', '精确率', '召回率', 'F1分数', 'CV均值']\n",
    "fig, axes = plt.subplots(2, 3, figsize=(18, 12))\n",
    "axes = axes.ravel()\n",
    "\n",
    "for idx, metric in enumerate(metrics):\n",
    "    if idx < 5:\n",
    "        ax = axes[idx]\n",
    "        sns.barplot(data=results_df, x='模型', y=metric, ax=ax)\n",
    "        ax.set_title(f'{metric}对比', fontsize=12, fontweight='bold')\n",
    "        ax.set_xticklabels(ax.get_xticklabels(), rotation=45, ha='right')\n",
    "        ax.set_ylim(0.8, 1.05)\n",
    "        \n",
    "        # 添加数值标签\n",
    "        for i, v in enumerate(results_df[metric]):\n",
    "            ax.text(i, v + 0.005, f'{v:.3f}', ha='center', va='bottom')\n",
    "\n",
    "# 训练时间对比\n",
    "sns.barplot(data=results_df, x='模型', y='训练时间(s)', ax=axes[5])\n",
    "axes[5].set_title('训练时间对比', fontsize=12, fontweight='bold')\n",
    "axes[5].set_xticklabels(axes[5].get_xticklabels(), rotation=45, ha='right')\n",
    "\n",
    "for i, v in enumerate(results_df['训练时间(s)']):\n",
    "    axes[5].text(i, v + 0.0005, f'{v:.4f}', ha='center', va='bottom')\n",
    "\n",
    "plt.suptitle('不同模型性能对比', fontsize=16)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. 混淆矩阵对比"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 绘制混淆矩阵\n",
    "n_models = len(models)\n",
    "n_cols = 4\n",
    "n_rows = (n_models + n_cols - 1) // n_cols\n",
    "\n",
    "fig, axes = plt.subplots(n_rows, n_cols, figsize=(20, 5*n_rows))\n",
    "axes = axes.ravel() if n_models > 1 else [axes]\n",
    "\n",
    "for idx, (name, (y_pred, _)) in enumerate(predictions.items()):\n",
    "    cm = confusion_matrix(y_test, y_pred)\n",
    "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[idx],\n",
    "                xticklabels=['setosa', 'versicolor'],\n",
    "                yticklabels=['setosa', 'versicolor'])\n",
    "    axes[idx].set_title(name, fontsize=11, fontweight='bold')\n",
    "    axes[idx].set_xlabel('预测标签')\n",
    "    axes[idx].set_ylabel('真实标签')\n",
    "\n",
    "# 隐藏多余的子图\n",
    "for idx in range(len(predictions), len(axes)):\n",
    "    axes[idx].axis('off')\n",
    "\n",
    "plt.suptitle('混淆矩阵对比', fontsize=16)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. ROC 曲线对比"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(10, 8))\n",
    "\n",
    "for name, (y_pred, y_pred_proba) in predictions.items():\n",
    "    if y_pred_proba is not None:\n",
    "        fpr, tpr, _ = roc_curve(y_test, y_pred_proba)\n",
    "        roc_auc = auc(fpr, tpr)\n",
    "        plt.plot(fpr, tpr, lw=2, label=f'{name} (AUC = {roc_auc:.3f})')\n",
    "\n",
    "# 绘制对角线\n",
    "plt.plot([0, 1], [0, 1], 'k--', lw=2, label='随机猜测 (AUC = 0.500)')\n",
    "\n",
    "plt.xlim([0.0, 1.0])\n",
    "plt.ylim([0.0, 1.05])\n",
    "plt.xlabel('假阳性率 (False Positive Rate)')\n",
    "plt.ylabel('真阳性率 (True Positive Rate)')\n",
    "plt.title('ROC 曲线对比')\n",
    "plt.legend(loc=\"lower right\")\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. 雷达图对比"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 归一化指标到 0-1 范围\n",
    "radar_metrics = ['准确率', '精确率', '召回率', 'F1分数', 'CV均值']\n",
    "radar_data = results_df[radar_metrics].values\n",
    "\n",
    "# 计算角度\n",
    "angles = np.linspace(0, 2 * np.pi, len(radar_metrics), endpoint=False).tolist()\n",
    "angles += angles[:1]  # 闭合雷达图\n",
    "\n",
    "# 创建雷达图\n",
    "fig, ax = plt.subplots(figsize=(12, 12), subplot_kw=dict(polar=True))\n",
    "\n",
    "# 绘制每个模型\n",
    "colors = plt.cm.tab10(np.linspace(0, 1, len(models)))\n",
    "for idx, (name, row) in enumerate(zip(results_df['模型'], radar_data)):\n",
    "    values = row.tolist()\n",
    "    values += values[:1]  # 闭合\n",
    "    ax.plot(angles, values, 'o-', linewidth=2, label=name, color=colors[idx])\n",
    "    ax.fill(angles, values, alpha=0.15, color=colors[idx])\n",
    "\n",
    "# 设置标签\n",
    "ax.set_xticks(angles[:-1])\n",
    "ax.set_xticklabels(radar_metrics, fontsize=11)\n",
    "ax.set_ylim(0.8, 1.0)\n",
    "ax.set_title('模型性能雷达图', fontsize=16, pad=20)\n",
    "ax.legend(loc='upper right', bbox_to_anchor=(1.3, 1.1))\n",
    "ax.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. 综合评分"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 计算综合评分（准确率 + 精确率 + 召回率 + F1 + CV均值）的平均\n",
    "results_df['综合评分'] = results_df[radar_metrics].mean(axis=1)\n",
    "results_df = results_df.sort_values('综合评分', ascending=False)\n",
    "\n",
    "print(\"\\n按综合评分排序:\")\n",
    "print(results_df[['模型', '综合评分', '准确率', 'F1分数', '训练时间(s)']].to_string(index=False))\n",
    "\n",
    "# 可视化综合评分\n",
    "plt.figure(figsize=(12, 6))\n",
    "bars = plt.barh(results_df['模型'], results_df['综合评分'], alpha=0.7)\n",
    "plt.xlabel('综合评分')\n",
    "plt.title('模型综合评分排名')\n",
    "plt.xlim(0.85, 1.0)\n",
    "\n",
    "# 添加数值标签\n",
    "for bar, score in zip(bars, results_df['综合评分']):\n",
    "    plt.text(score + 0.005, bar.get_y() + bar.get_height()/2,\n",
    "             f'{score:.4f}', va='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
